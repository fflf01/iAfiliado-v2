# Ambiente (development | production)
NODE_ENV=development

# Banco de dados SQLite (caminho relativo ao diretorio backend/)
DB_PATH=./data/iafiliado.db

# JWT (obrigatório para login e registro — use uma string longa e aleatória)
JWT_SECRET=

# Discord — webhook para notificações de tickets (opcional)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# Timeout em ms para requisições ao Discord (default 8000; min 1000, max 60000)
# DISCORD_WEBHOOK_TIMEOUT_MS=8000

# CORS — lista de origens separadas por vírgula
# Em produção (NODE_ENV=production), CORS_ORIGINS é OBRIGATÓRIO
# CORS_ORIGINS=https://seu-dominio.com,https://www.seu-dominio.com

# Porta do servidor (opcional; o backend usa 3000 por padrão no código)
# PORT=3000

xis# reCAPTCHA v2 — chave secreta para validar token no login (após 3 falhas por IP)
# Se não definida, a verificação é desativada (dev) ou sempre aprovada em teste.
# RECAPTCHA_SECRET_KEY=

# Email — notificação de tentativas de login suspeitas (após bloqueio de conta)
# SendGrid: SENDGRID_API_KEY=SG.xxx
# Remetente: EMAIL_FROM= e EMAIL_FROM_NAME= (opcional)
# SENDGRID_API_KEY=
# EMAIL_FROM=noreply@seu-dominio.com
# EMAIL_FROM_NAME=iAfiliado
